# GlamHub Social (Postiz Fork) - Configuration
# Copy to .env and fill in your API keys

# Postiz Settings
POSTIZ_URL=http://localhost:4007
POSTIZ_JWT_SECRET=change-this-to-a-random-string
POSTIZ_DB_PASSWORD=postiz123

# ─── Social Platform API Keys ────────────────────────
# Get these from each platform's developer console

# Twitter/X: https://developer.twitter.com/
X_API_KEY=
X_API_SECRET=

# Facebook/Instagram: https://developers.facebook.com/
# (Instagram uses the same Facebook App)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# YouTube: https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok: https://developers.tiktok.com/
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Pinterest: https://developers.pinterest.com/
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Threads (uses Facebook App): https://developers.facebook.com/
THREADS_APP_ID=
THREADS_APP_SECRET=

# Claude API (used by Postiz AI features instead of OpenAI)
ANTHROPIC_API_KEY=
